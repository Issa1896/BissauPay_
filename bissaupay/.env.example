# ============================================================
# BISSAUPAY — Variáveis de Ambiente
# cp .env.example .env  e preencha com os seus valores
# NUNCA commite o .env no git
# ============================================================

NODE_ENV=development
PORT=3000
API_VERSION=v1
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# ── PostgreSQL ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bissaupay
DB_USER=bissaupay_user
DB_PASSWORD=sua_senha_aqui
DB_POOL_MAX=10

# ── JWT ──────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=SUBSTITUA_POR_UMA_CHAVE_LONGA_E_ALEATORIA_COM_PELO_MENOS_64_CARACTERES
JWT_EXPIRES_IN=7d

# ── OTP ──────────────────────────────────────────────────────
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=3

# ── SMS ──────────────────────────────────────────────────────
# Use 'mock' para desenvolvimento (exibe no console, não envia SMS real)
SMS_PROVIDER=mock
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=BissauPay
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_PHONE=

# ── Taxas (decimal) ──────────────────────────────────────────
FEE_P2P=0.005
FEE_PAYMENT=0.010
FEE_REMITTANCE=0.020

# ── Limites em centavos de XOF ───────────────────────────────
LIMIT_DAILY_BASIC=50000000
LIMIT_DAILY_VERIFIED=200000000
LIMIT_DAILY_MERCHANT=500000000
LIMIT_SINGLE_TX=10000000

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Câmbio ───────────────────────────────────────────────────
EXCHANGE_API_KEY=
EXCHANGE_BASE_URL=https://v6.exchangerate-api.com/v6
OXR_API_KEY=

# ── Wise (remessas) ──────────────────────────────────────────
WISE_API_KEY=
WISE_PROFILE_ID=

# ── Wave (remessas Senegal) ──────────────────────────────────
WAVE_API_KEY=

# ── Orange Money ─────────────────────────────────────────────
ORANGE_BEARER_TOKEN=
ORANGE_MERCHANT_KEY=
ORANGE_RETURN_URL=
ORANGE_CANCEL_URL=
ORANGE_NOTIF_URL=

# ── Provedores de recarga ────────────────────────────────────
EAGB_API_URL=
EAGB_API_KEY=
SAAB_API_URL=
SAAB_API_KEY=

# ── Logs ─────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/bissaupay.log

# ── App ──────────────────────────────────────────────────────
APP_URL=http://localhost:3000
ADMIN_SECRET=CHAVE_ADMIN_PARA_ENDPOINTS_INTERNOS
